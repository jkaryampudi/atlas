# One T0-T9 daily cycle (oneshot; fired by atlas-daily.timer).
[Unit]
Description=Atlas daily cycle (T0-T9)
After=docker.service network-online.target
OnFailure=atlas-alert@%n.service

[Service]
Type=oneshot
User=__USER__
WorkingDirectory=__REPO__
EnvironmentFile=__REPO__/.env
ExecStart=__REPO__/.venv/bin/python -m atlas.ops.daily
# the pipeline pages on its own failures; OnFailure catches a dead process
